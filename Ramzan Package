function doGet() {
  // یہ ویب ایپلیکیشن کے لیے HTML پیج لوڈ کرے گا
  return HtmlService.createTemplateFromFile('index') // 'index' کو آپ اپنے HTML فائل کا نام دیں
    .evaluate()
    .addMetaTag('viewport', 'width=device-width, initial-scale=1') // موبائل ڈیوائسز کے لیے سٹائل
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL); // XFrameOptions کو ALLOWALL کرنے سے یہ ویب ایپلیکیشن کسی بھی ڈومین میں ایمبیڈ ہو سکتی ہے
}

function submitData(obj) {
  // Google Sheet ID اور شیٹ کا نام درج کریں
  var spreadsheetId = "1dLf6F7NOoUREw-B9wMmh-91XED9CaSwbqqevmUb8jJ4"; 
  var sheetName = "Ramzan Relief Packge 2025 District Tank";
  
  // شیٹ کو کھولنا
  var ss = SpreadsheetApp.openById(spreadsheetId);
  var sheet = ss.getSheetByName(sheetName);
  
  // پورے شیٹ کا ڈیٹا ایک ہی بار حاصل کرنا
  var data = sheet.getDataRange().getValues(); 
  var flag = 1;

  // پورے ڈیٹا پر لوپ لگانا
  for (var i = 0; i < data.length; i++) {
    var currentId = data[i][0]; // پہلی کالم سے شناختی کارڈ نمبر حاصل کرنا
    
    if (currentId == obj) {
      flag = 0;
      
      // باقی کالموں کی ویلیو حاصل کرنا
      var columnB = data[i][1];
      var columnC = data[i][2];
      var columnD = data[i][3];
      var columnE = data[i][4];
      var columnF = data[i][5];
      var columnG = data[i][6];
      
      // نتیجہ واپس کرنا
      var resultHtml = "<table><tr><th colspan=2><center>آپکے شناختی کارڈ کی معلومات</center></th></tr><tr><td>CNIC:</td><td>"
        + obj + "</td></tr><tr><td>msisdn:</td><td>" + columnB + "</td></tr><tr><td>cashin_trx_id:</td><td>"
        + columnC + "</td></tr><tr><td>cashin_date:</td><td>" + columnD + "</td></tr><tr><td>cashout_trans_id:</td><td>" 
        + columnE + "</td></tr><tr><td>cashout_date:</td><td>" + columnF + "</td></tr><tr><td>retailer_msisdn:</td><td>" 
        + columnG + "</td></tr></table>";

      return resultHtml;
    }
  }

  if (flag == 1) {
    var notFoundMessage = "DATA IS NOT FOUND!";
    return notFoundMessage;
  }
}


